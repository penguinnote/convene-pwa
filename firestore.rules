rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 공지: 누구나 읽기, 이메일 관리자만 쓰기 (익명 로그인 차단)
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && request.auth.token.email != null;
    }
    // 라이브 진행 상태: 누구나 읽기, 이메일 관리자만 쓰기
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    // 토큰: 누구나 자기 토큰 등록 가능, 읽기는 이메일 관리자만(통계용).
    // 서버 함수는 Admin SDK라 규칙 우회.
    match /tokens/{token} {
      allow create: if true;
      allow read: if request.auth != null && request.auth.token.email != null;
      allow update, delete: if false;
    }
    // 사용자 닉네임/팀: 누구나 읽기, 본인 또는 이메일 관리자만 쓰기
    // (관리자 팀 편성이 남의 users 문서를 수정하므로 email 관리자 허용)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || request.auth.token.email != null);
    }
    // 관리자 로그인 기록: 이메일 관리자만 읽기, 본인 문서만 쓰기(통계 뷰 관리자 수)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.token.email != null;
      allow write: if request.auth != null && request.auth.token.email != null
                   && request.auth.uid == uid;
    }
    // 이벤트 로그: 로그인 사용자가 자기 uid로만 생성, 읽기는 이메일 관리자만(통계 뷰)
    match /events/{id} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && request.auth.token.email != null;
      allow update, delete: if false;
    }
    // 푸시 도달 로그: 기록은 Functions(Admin SDK)만, 읽기는 이메일 관리자만(통계 뷰)
    match /pushLogs/{id} {
      allow read: if request.auth != null && request.auth.token.email != null;
      allow write: if false;
    }
  }
}
