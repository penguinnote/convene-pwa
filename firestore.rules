rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 공지: 누구나 읽기, 로그인한 관리자만 쓰기
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
    // 라이브 진행 상태: 누구나 읽기, 이메일 관리자만 쓰기
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
    // 토큰: 누구나 자기 토큰 등록 가능, 읽기는 막음(서버 함수는 admin 권한이라 우회)
    match /tokens/{token} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    // 사용자 닉네임/팀: 누구나 읽기, 본인 또는 이메일 관리자만 쓰기
    // (관리자 팀 편성이 남의 users 문서를 수정하므로 email 관리자 허용)
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || request.auth.token.email != null);
    }
    // 이벤트 로그: 로그인 사용자가 자기 uid로만 생성, 읽기/수정/삭제 불가(분석은 Admin SDK)
    match /events/{id} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }
    // 푸시 도달 로그: Functions(Admin SDK)만 기록/조회
    match /pushLogs/{id} {
      allow read, write: if false;
    }
  }
}
