rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /announcements/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /profiles/{uid}/{file} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
